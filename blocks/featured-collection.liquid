
{% assign block_settings = block.settings %}
{% assign vis_class = '' %}
{% if block_settings.visibility == 'desktop' %}{% assign vis_class = 'hide-on-mobile' %}{% elsif block_settings.visibility == 'mobile' %}{% assign vis_class = 'hide-on-desktop' %}{% endif %}

<div class="visibility-wrapper {{ vis_class }}">
<div
  class="featured-collection-block"
  {{ block.shopify_attributes }}
>
  {% content_for 'blocks' %}
</div>
</div>

{% schema %}
{
  "name": "t:names.featured_collection",
  "tag": null,
  "blocks": [
    {
      "type": "@theme"
    },
    {
      "type": "@app"
    }
  ],
  "settings": [
    {
      "type": "collection",
      "id": "collection",
      "label": "t:settings.collection"
    }
    ,
    {
      "type": "header",
      "content": "Visibility"
    },
    {
      "type": "select",
      "id": "visibility",
      "label": "Visible on",
      "options": [
        { "value": "both", "label": "All devices" },
        { "value": "mobile", "label": "Mobile only" },
        { "value": "desktop", "label": "Desktop only" }
      ],
      "default": "both"
    }
  ],
  "presets": []
}
{% endschema %}

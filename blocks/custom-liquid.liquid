

{% assign block_settings = block.settings %}
{% assign vis_class = '' %}
{% if block_settings.visibility == 'desktop' %}{% assign vis_class = 'hide-on-mobile' %}{% elsif block_settings.visibility == 'mobile' %}{% assign vis_class = 'hide-on-desktop' %}{% endif %}
<div class="visibility-wrapper {{ vis_class }}">
<div>
  {{ block.settings.custom_liquid }}
</div>
</div>

{% schema %}
{
  "name": "t:names.custom_liquid",
  "tag": null,
  "settings": [
    {
      "type": "liquid",
      "id": "custom_liquid",
      "label": "t:settings.custom_liquid",
      "info": "t:info.custom_liquid"
    }
    ,
    {
      "type": "header",
      "content": "Visibility"
    },
    {
      "type": "select",
      "id": "visibility",
      "label": "Visible on",
      "options": [
        { "value": "both", "label": "All devices" },
        { "value": "mobile", "label": "Mobile only" },
        { "value": "desktop", "label": "Desktop only" }
      ],
      "default": "both"
    }
  ],
  "presets": [
    {
      "name": "t:names.custom_liquid",
      "category": "t:categories.custom"
    }
  ]
}
{% endschema %}
